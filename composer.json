{
    "name": "andmarruda/instagram-laravel",
    "description": "Laravel package for Instagram Business Login OAuth using Ports and Adapters",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Anderson Marruda",
            "email": "andmarruda@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Andmarruda\\InstagramLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Andmarruda\\InstagramLaravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Andmarruda\\InstagramLaravel\\Laravel\\InstagramServiceProvider"
            ],
            "aliases": {
                "Instagram": "Andmarruda\\InstagramLaravel\\Laravel\\Facades\\Instagram"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
